{
  "name": "remotion-video-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts",
    "render:all": "for id in $(remotion compositions src/index.ts --quiet); do remotion render src/index.ts $id out/$id.mp4; done",
    "new-video": "bash scripts/new-video.sh",
    "generate:audio": "tsx scripts/generate-audio.ts",
    "generate:voiceover": "tsx scripts/generate-voiceover.ts",
    "translate:srt": "tsx scripts/translate-srt.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ scripts/",
    "lint:fix": "eslint src/ scripts/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:editor": "vitest run --config editor/vitest.config.ts",
    "test:editor:watch": "vitest --config editor/vitest.config.ts",
    "test:all": "vitest run && vitest run --config editor/vitest.config.ts",
    "editor": "vite serve editor --config editor/vite.config.ts --port 3001",
    "editor:build": "vite build --config editor/vite.config.ts",
    "editor:preview": "vite preview --config editor/vite.config.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@remotion/bundler": "4.0.432",
    "@remotion/captions": "^4.0.438",
    "@remotion/cli": "4.0.432",
    "@remotion/google-fonts": "4.0.432",
    "@remotion/lottie": "^4.0.438",
    "@remotion/media-utils": "4.0.432",
    "@remotion/player": "^4.0.432",
    "@remotion/transitions": "4.0.432",
    "elevenlabs": "^1.59.0",
    "lottie-web": "^5.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "remotion": "4.0.432",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}

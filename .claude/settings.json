{
	"mcpServers": {
		"stocky": {
			"command": "uv",
			"args": ["run", "--python", "3.12", "--with", "mcp,pycurl", "/Users/tanguy/dev/projets/remotion-video-template/.mcp/stocky/stocky_mcp.py"],
			"env": {
				"PEXELS_API_KEY": "${PEXELS_API_KEY}",
				"UNSPLASH_ACCESS_KEY": "${UNSPLASH_ACCESS_KEY}"
			}
		},
		"suno": {
			"command": "uv",
			"args": ["run", "--python", "3.12", "--with", "mcp,httpx,python-dotenv", "/Users/tanguy/dev/projets/remotion-video-template/.mcp/suno/server.py"],
			"env": {
				"SUNO_API_KEY": "${SUNO_API_KEY}",
				"SUNO_API_BASE_URL": "https://api.sunoapi.org"
			}
		},
		"jamendo": {
			"command": "uv",
			"args": ["run", "--python", "3.12", "--with", "mcp,httpx,python-dotenv", "/Users/tanguy/dev/projets/remotion-video-template/.mcp/jamendo/server.py"],
			"env": {
				"JAMENDO_API_KEY": "${JAMENDO_API_KEY}"
			}
		},
		"krea": {
			"command": "npx",
			"args": ["-y", "krea-mcp"],
			"env": {
				"KREA_API_KEY": "${KREA_API_KEY}"
			}
		},
		"elevenlabs": {
			"command": "uvx",
			"args": ["elevenlabs-mcp"],
			"env": {
				"ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
				"ELEVENLABS_MCP_BASE_PATH": "${ELEVENLABS_MCP_BASE_PATH}"
			}
		}
	}
}

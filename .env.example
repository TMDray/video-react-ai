# Set up uploads of user assets to S3 and Lambda renders
# https://remotion.dev/docs/editor-starter/asset-uploads
REMOTION_AWS_BUCKET_NAME=
REMOTION_AWS_SECRET_ACCESS_KEY=
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_REGION=
REMOTION_AWS_TRANSFER_ACCELERATION=false

# Required for captioning
# https://www.remotion.dev/docs/editor-starter/captioning
OPENAI_API_KEY=

# Stock images & videos (Stocky MCP)
# https://www.pexels.com/api/ (free)
PEXELS_API_KEY=
# https://unsplash.com/developers (free)
UNSPLASH_ACCESS_KEY=

# AI Music generation (Suno MCP)
# https://sunoapi.org (paid)
SUNO_API_KEY=
SUNO_API_BASE_URL=https://api.sunoapi.org

# Royalty-free music (Jamendo MCP)
# https://www.jamendo.com/developers (free)
JAMENDO_API_KEY=
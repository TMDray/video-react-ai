# Required for captioning (Voxtral speech-to-text)
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Stock images & videos (Stocky MCP)
# https://www.pexels.com/api/ (free)
PEXELS_API_KEY=
# https://unsplash.com/developers (free)
UNSPLASH_ACCESS_KEY=

# AI Music generation (Suno MCP)
# https://sunoapi.org (paid)
SUNO_API_KEY=
SUNO_API_BASE_URL=https://api.sunoapi.org

# Royalty-free music (Jamendo MCP)
# https://www.jamendo.com/developers (free)
JAMENDO_API_KEY=

# AI Video generation — Kling & Hailuo 2.3 (Krea MCP via fal.ai)
# https://www.krea.ai/api-keys
KREA_API_KEY=

# Text-to-Speech & Voice cloning (ElevenLabs MCP)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Dossier de sortie pour les fichiers audio générés (défaut: ~/Desktop)
ELEVENLABS_MCP_BASE_PATH=